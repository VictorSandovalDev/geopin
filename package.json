{
  "name": "geopin",
  "version": "0.1.0",
  "private": true,
  "description": "GeoPin — multiplayer geography-guessing SaaS game",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @geopin/api prisma:push",
    "db:migrate": "pnpm --filter @geopin/api prisma:migrate",
    "db:seed": "pnpm --filter @geopin/api prisma:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  }
}
