# =======================
#  GeoPin — env example
# =======================
# Copy to .env at the repo root (for docker-compose) and also populate
# apps/api/.env and apps/web/.env.local for local dev.

# ---- API (NestJS) ----
DATABASE_URL="postgresql://geopin:geopin@localhost:5432/geopin?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000"

# Optional OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- WEB (Next.js) ----
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"
# Mapillary optional token — without it the StreetView falls back to the offline synthetic viewer.
NEXT_PUBLIC_MAPILLARY_TOKEN=""
